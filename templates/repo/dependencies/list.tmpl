{{template "base/head" .}}
<div class="page-content repository dependencies">
	{{template "repo/header" .}}
	<div class="ui container">
		<div class="ui grid">
			<div class="twelve wide column content">
				<div class="repo-button-row">
					<div class="repo-button-row-left">
						<span class="tw-font-semibold tw-text-lg">{{ctx.Locale.Tr "dependencies.title"}}</span>
					</div>
					<div class="repo-button-row-right">
						{{if $.VulnerabilityCheckEnabled}}
							{{if $.CanWriteDependencies}}
								<form method="post" action="{{$.RepoLink}}/dependencies/scan-vulnerabilities">
									<button class="ui primary small button">{{ctx.Locale.Tr "dependencies.scan_vulnerabilities"}}</button>
								</form>
							{{end}}
						{{end}}
					</div>
				</div>
				<div class="ui divider"></div>
				{{if .DependenciesByEcosystem}}
					{{range $ecosystem, $deps := .DependenciesByEcosystem}}
						<div class="tw-mb-8">
							<h4 class="ui top attached header">
								{{$ecosystem}}
							</h4>
							<div class="ui attached segment">
							<table class="ui very basic table">
								<thead>
									<tr>
										<th style="width:25%">{{ctx.Locale.Tr "repo.dependencies.package_name"}}</th>
										<th style="width:12%">{{ctx.Locale.Tr "repo.dependencies.package_version"}}</th>
										<th style="width:8%">{{ctx.Locale.Tr "repo.dependencies.dep_type"}}</th>
										{{if $.VulnerabilityCheckEnabled}}
											<th style="width:8%">{{ctx.Locale.Tr "dependencies.severity"}}</th>
											<th style="width:35%">{{ctx.Locale.Tr "dependencies.vulnerabilities"}}</th>
											<th style="width:12%">{{ctx.Locale.Tr "dependencies.action"}}</th>
										{{end}}
									</tr>
								</thead>
								<tbody>
									{{range $deps}}
										<tr>
											{{$vulns := index $.VulnerabilitiesByDep .Name}}
											<td>{{.Name}}</td>
											<td><code>{{.Version}}</code></td>
											<td>{{.Type}}</td>
											{{if $.VulnerabilityCheckEnabled}}
												<td>
													{{if $vulns}}
														{{range $vuln := $vulns}}
															<div class="tw-py-1">
															{{$severityClass := "grey"}}
															{{if eq $vuln.Severity "CRITICAL"}}{{$severityClass = "red"}}
															{{else if eq $vuln.Severity "HIGH"}}{{$severityClass = "orange"}}
															{{else if eq $vuln.Severity "MEDIUM"}}{{$severityClass = "yellow"}}
															{{else if eq $vuln.Severity "LOW"}}{{$severityClass = "green"}}
															{{end}}
															<span class="ui label {{$severityClass}}">{{$vuln.Severity}}</span>
															</div>
														{{end}}
													{{end}}
												</td>
												<td>
													{{if $vulns}}
														{{range $vuln := $vulns}}
															<div class="tw-py-1">
															{{$severityClass := "grey"}}
															{{if eq $vuln.Severity "CRITICAL"}}{{$severityClass = "red"}}
															{{else if eq $vuln.Severity "HIGH"}}{{$severityClass = "orange"}}
															{{else if eq $vuln.Severity "MEDIUM"}}{{$severityClass = "yellow"}}
															{{else if eq $vuln.Severity "LOW"}}{{$severityClass = "green"}}
															{{end}}
															{{if $vuln.SourceURL}}
																<a href="{{$vuln.SourceURL}}" target="_blank" rel="noopener noreferrer" class="ui label {{$severityClass}}" data-tooltip-content="{{$vuln.Title}}">
																	{{$vuln.SourceID}}
																</a>
															{{else}}
																<span class="ui label {{$severityClass}}" data-tooltip-content="{{$vuln.Title}}">{{$vuln.SourceID}}</span>
															{{end}}
															</div>
														{{end}}
													{{else}}
														<span class="ui green label">{{ctx.Locale.Tr "dependencies.no_vulnerabilities"}}</span>
													{{end}}
												</td>
												<td>
													{{if $vulns}}
														{{$depName := .Name}}
														{{range $vuln := $vulns}}
															<div class="tw-py-1">
															{{if $vuln.IssueID}}
																<a href="{{$.RepoLink}}/issues/{{$vuln.IssueID}}">#{{$vuln.IssueID}}</a>
															{{else if $.CanWriteDependencies}}
																<form method="post" action="{{$.RepoLink}}/dependencies/create-issue" class="tw-inline">
																	<input type="hidden" name="vuln_id" value="{{$vuln.ID}}">
																	<button type="submit" class="ui mini basic button" data-tooltip-content="{{ctx.Locale.Tr "dependencies.create_issue"}}">{{ctx.Locale.Tr "dependencies.create_issue"}}</button>
																</form>
															{{end}}
															</div>
														{{end}}
													{{end}}
												</td>
											{{end}}
										</tr>
									{{end}}
								</tbody>
							</table>
						</div>
						<div class="ui bottom attached header"></div>
						</div>
					{{end}}
				{{else}}
					<div class="ui empty center">
						<p>{{ctx.Locale.Tr "dependencies.empty"}}</p>
					</div>
				{{end}}
			</div>
		</div>
	</div>
</div>
{{template "base/footer" .}}
